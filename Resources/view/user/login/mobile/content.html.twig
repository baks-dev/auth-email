<main class="main">

	<div class="mt-3">
		{#{{ include(_self|replace({ "content.html.twig": "breadcrumb.html.twig" })) }}#}
	</div>

	<div class="container d-flex flex-column justify-content-center w-100 my-5 pb-3">

		{#<div class="w-75 d-flex position-relative">
			<img data-src="/assets/login/img/login.webp" src="/assets/img/empty.png"
				 class="lazy position-absolute start-0 ms-2"
				 alt="..." width="500"
			>
		</div>#}

		<div class="d-flex gap-3 mb-4 align-items-end small">
			<h3 class="modal-title text-uppercase h4 fw-bold w-75">Авторизация</h3>
			<a href="{{ path('AuthEmail:user.registration') }}" aria-label="Регистация" class="small mb-1 w-50">Регистация</a>
		</div>


		<div class="w-100">
			<form action="{{ path('AuthEmail:user.login') }}" class="d-flex flex-column align-items-end p-4 border shadow rounded-3 w-100">


				<div class="d-flex flex-column gap-4 w-100 small">

					<div class="w-100 d-flex flex-column gap-2">
						<label for="login-email">Электронная почта:</label>
						<input class="form-control rounded-3"
							   type="email" id="login-email" required="">
					</div>

					<div class="w-100 d-flex flex-column gap-2">

						<div class="d-flex justify-content-between gap-5 ">
							<label for="login-password" class="w-50">Пароль:</label>
							<a href="#" aria-label="Забыли пароль?" class="small w-50">Забыли пароль?</a>
						</div>

						<input class="form-control rounded-3"
							   type="password" id="login-password"
							   required="">
					</div>

					<div class="w-100">
						<button type="submit" class="btn btn-lg btn-danger w-100  rounded-3">
							<span class="small text-uppercase fw-bolder">Войти</span>
						</button>
					</div>

				</div>

			</form>
		</div>

	</div>

</main>


